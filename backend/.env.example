# pikCarz Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database (Auto-created by Vercel Neon Integration)
POSTGRES_PRISMA_URL=postgresql://user:password@host/database

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend
FRONTEND_URL=https://pikcarz.co.za
BACKEND_URL=https://pikcarz.vercel.app

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# PayFast (Payment Gateway)
PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-secure-passphrase
PAYFAST_MODE=sandbox  # Use 'live' for production

# Admin Account
ADMIN_EMAIL=admin@pikcarz.co.za
ADMIN_PASSWORD=your-secure-admin-password
